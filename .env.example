# Runtime
NODE_ENV=development
PORT=7000
FRONTEND_URL=http://localhost:3000
# Optional comma-separated additional browser origins. Production values must use HTTPS.
FRONTEND_URLS=
ALLOWED_ORIGINS=
BACKEND_PUBLIC_URL=http://localhost:7000
PUBLIC_ASSET_BASE_URL=
INTERNAL_API_ORIGIN=http://127.0.0.1:7000
# Browsers use the same-origin Next.js proxy in production.
NEXT_PUBLIC_API_URL=/api
# Production: use an absolute path on persistent encrypted storage.
UPLOADS_ROOT=
# Development-only hop count. Production instead requires explicit trusted
# proxy IPs/CIDRs, for example: loopback or 10.0.0.0/8,192.0.2.10
TRUST_PROXY_HOPS=0
TRUST_PROXY_ADDRESSES=

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Authentication (generate independent random values of at least 32 bytes)
JWT_SECRET=
OTP_SECRET=
JWT_EXPIRES_IN=12h
AUTH_COOKIE_MAX_AGE_MS=43200000

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ZeilaLink <noreply@zeilalink.com>
CONTACT_EMAIL_TO=contact@zeilalink.com

# Development sample seed (use unique passwords of at least 12 characters)
SEED_ADMIN_PASSWORD=
SEED_WORKER_PASSWORD=
SEED_EMPLOYEE_PASSWORD=
SEED_EMPLOYER_PASSWORD=
SEED_PROVIDER_PASSWORD=
ALLOW_PRODUCTION_SEED=false

# Optional integrations
REDIS_URL=
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=usd
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
SMS_TO=
