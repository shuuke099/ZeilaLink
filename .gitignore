# Dependencies
node_modules/
**/node_modules/

# Environment
.env
.env.*
!.env.example

# Never commit local/server environment files
backend/.env
frontend/.env.local
frontend/.env.production

# Build output
dist/
**/dist/
build/
**/build/

# Next.js
.next/
**/.next/
.next-dev/
**/.next-dev/

# Coverage
coverage/

# Logs
*.log
*.err

# User-uploaded files (never commit resumes, documents, or account media)
backend/uploads/

# TypeScript
*.tsbuildinfo

# Certificates
*.pem
*.key
*.crt

# macOS
.DS_Store

# PM2
.pm2/

# Prisma Studio
prisma/*.db
prisma/*.db-journal
