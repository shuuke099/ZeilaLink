{
  "name": "somali-youth-job-platform",
  "version": "1.0.0",
  "description": "Bilingual job and skills platform for Somali youth",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "pnpm run dev:prepare; concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:prepare": "kill-port 3000 7000 || true && rimraf frontend/.next-dev",
    "dev:backend": "pnpm -C backend run dev",
    "dev:frontend": "pnpm -C frontend run dev",
    "seed": "pnpm -C backend run prisma:seed",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "build:backend": "pnpm -C backend run build",
    "build:frontend": "pnpm -C frontend run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "kill-port": "^2.0.1",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "react-toastify": "^11.0.5"
  }
}
